# =============================================================================
# PayD Backend Environment Configuration
# =============================================================================
# Copy this file to `backend/.env` before running backend services:
#   cp backend/.env.example backend/.env
#
# CRITICAL SECURITY NOTES:
# - Never commit real secrets or credentials to version control
# - Use strong, random values for all JWT secrets (minimum 32 characters)
# - Rotate JWT secrets regularly in production by updating platform settings
# - Use production-grade credentials and URLs only in staging/production
# - Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"


# =============================================================================
# Core Server Runtime Configuration (REQUIRED - affects server startup)
# =============================================================================

# API Port Configuration
# The port number the backend API server will listen on for incoming requests
# Default: 3000 | Common values: 3000, 3001, 8000, 8080
# In Docker: usually 3000 | Production should use load balancer default ports
PORT=3001

# Application Environment
# Controls logging verbosity, error handling behavior, and feature flags
# Values: development (verbose logs, hot reload) | production (minimal logs, optimized)
#         test (silent, in-memory DB preferred)
# Default: development
NODE_ENV=development

# Primary CORS Origin
# The single origin (domain + port) allowed to make cross-origin API requests
# Use the exact URL of your frontend: protocol://hostname:port (no trailing slash)
# Example for local dev: http://localhost:5173
# Example for staging: https://staging.payd.io
# Important: Must match frontend's actual origin or auth/API calls will be blocked
CORS_ORIGIN=http://localhost:5173

# Additional Allowed CORS Origins (comma-separated)
# For multiple environments (staging, production, other front-end apps)
# Only used if specified; does not override CORS_ORIGIN
# Example: CORS_ALLOWED_ORIGINS=https://staging.payd.io,https://app.payd.io,https://admin.payd.io
# CORS_ALLOWED_ORIGINS=https://staging.payd.io,https://app.payd.io

# Frontend Base URL
# Used for auth redirects and linking back to the frontend after login
# Must match the frontend's actual deployed URL (including protocol + port)
# Should be HTTPS in production for security
FRONTEND_URL=http://localhost:5173


# =============================================================================
# Authentication & JWT Configuration (REQUIRED - security-critical)
# =============================================================================

# JWT Access Token Secret
# Signing secret for short-lived access tokens (typically 15min - 1h expiry)
# MUST be at least 32 characters long and highly random
# Should be replaced immediately in production
# Generate once per environment and store securely (e.g., AWS Secrets Manager)
# Rotation: Change value, redeploy, then rotate tokens issued with old secret
# DO NOT use placeholder values like 'dev-jwt-secret' or 'replace-with-a-...'
JWT_SECRET=replace-with-a-long-random-secret

# JWT Refresh Token Secret
# Signing secret for long-lived refresh tokens (typically 7day - 30day expiry)
# MUST be different from JWT_SECRET (system enforces this)
# MUST be at least 32 characters long and highly random
# Separate secret enables revoking all access without invalidating refresh tokens
# Rotation: More complex than access token; requires token invalidation strategy
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret

# Google OAuth Credentials (optional - only if social login enabled)
# Obtain from: https://console.cloud.google.com/
# GOOGLE_CLIENT_ID: Public identifier for your OAuth application
# GOOGLE_CLIENT_SECRET: Secret credential (never expose publicly or in logs)
# GOOGLE_CALLBACK_URL: Exact redirect URL registered in Google Cloud Console
# Format: http(s)://hostname:port/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# GitHub OAuth Credentials (optional - only if social login enabled)
# Obtain from: https://github.com/settings/developers
# GITHUB_CLIENT_ID: Public identifier for your OAuth application
# GITHUB_CLIENT_SECRET: Secret credential (never expose publicly or in logs)
# GITHUB_CALLBACK_URL: Exact redirect URL registered in GitHub OAuth settings
# Format: http(s)://hostname:port/auth/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback


# =============================================================================
# Database Configuration (REQUIRED - data persistence)
# =============================================================================

# Primary Database Connection String
# Full PostgreSQL connection URL used by Prisma ORM and all migrations
# Format: postgresql://[username]:[password]@[host]:[port]/[database]
# For local dev with Docker: postgresql://payd_user:payd_password@localhost:5432/payd_db
# For managed services (AWS RDS, Heroku): Use connection string from provider
# Includes: auth credentials, host, port, database name
# Prisma will attempt migrations on this database at startup
DATABASE_URL=postgresql://payd_user:payd_password@localhost:5432/payd_db

# Database Host (Alternative to DATABASE_URL for split configuration)
# Only used if DATABASE_URL is not available; kept for backward compatibility
# Hostname or IP address where PostgreSQL is running
# Local: localhost | Docker: db or payd-postgres | Cloud: managed endpoint
DB_HOST=localhost

# Database Port (Alternative configuration)
# Port number PostgreSQL is listening on
# Standard PostgreSQL: 5432
# Custom Docker setup: may vary
DB_PORT=5432

# Database User (Alternative configuration)
# PostgreSQL user with permissions to create/modify tables and data
# Must have DDL (CREATE, ALTER, DROP) permissions for migrations
# Default for Docker example: payd_user
DB_USER=payd_user

# Database Password (Alternative configuration - SENSITIVE)
# Password for the database user
# Use strong, random value in production (min 16 chars, mixed case + symbols)
# Do not use common passwords or defaults
# NEVER log this value; mask in error messages
DB_PASSWORD=payd_password

# Database Name (Alternative configuration)
# Name of the PostgreSQL database (schema is managed by Prisma)
# Must be created before connection or Prisma migration will fail
# Naming: lowercase, underscores instead of spaces (e.g., payd_db, payd_prod)
DB_NAME=payd_db

# Redis Cache Connection (OPTIONAL - session/cache storage)
# Connection URL for Redis cache server
# Format: redis://[username]:[password]@[host]:[port]/[database]
# For local dev: redis://localhost:6379
# For authentication: redis://default:password@redis.example.com:6379
# For Redis cluster: rediscluster://...
# If omitted: some features may use in-memory fallback (not recommended for production)
# Used for: session storage, caching, rate limit counters
REDIS_URL=redis://localhost:6379


# =============================================================================
# Email Configuration (REQUIRED - transactional notifications)
# =============================================================================

# Email Service Provider
# Which service to use for sending transactional emails
# Values: resend (recommended, newer) | sendgrid (legacy support)
# Each provider requires its corresponding API key below
# Default: resend
EMAIL_PROVIDER=resend

# Sender Email Address
# "From" address shown in emails (must be verified with provider)
# Format: email@domain.com or localpart@example.com
# For Resend: must be verified in Resend dashboard
# For SendGrid: must be a verified sender identity
# Example: noreply@payd.io, support@payd.io
# Important: Users will see this address; name set by EMAIL_FROM_NAME
EMAIL_FROM_ADDRESS=noreply@payd.example.com

# Sender Display Name
# "From" name shown in emails alongside EMAIL_FROM_ADDRESS
# Displayed as: "PayD Payroll System <noreply@payd.io>"
# Helps recipients identify the sender
# Maximum 50 characters recommended
EMAIL_FROM_NAME=PayD Payroll System

# Resend API Key (if EMAIL_PROVIDER=resend)
# API authentication key from Resend service
# Obtain from: https://resend.com/api-keys
# Format: re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Leave empty if using SendGrid instead
# Permissions needed: Send transactional email
RESEND_API_KEY=

# SendGrid API Key (if EMAIL_PROVIDER=sendgrid)
# API authentication key from SendGrid account
# Obtain from: https://app.sendgrid.com/settings/api_keys
# Format: SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Leave empty if using Resend instead
# Permissions needed: Mail Send, no restrictions (or create restricted key)
SENDGRID_API_KEY=


# =============================================================================
# Rate Limiting & Transaction Throttling (RECOMMENDED - abuse prevention)
# =============================================================================

# Throttling Rate (Tokens Per Minute for contract operations)
# Controls how many blockchain contract operations can be queued per minute
# Higher = more throughput but higher cost | Lower = cost-effective but slower
# Typical: 10 (very conservative) to 500 (aggressive)
# Default: 100 | Consider Stellar network rate limits and costs
# Impact: Queue fills up → new requests delayed or rejected if queue full
THROTTLING_TPM=100

# Throttling Queue Maximum Size
# Maximum number of requests that can be queued while waiting for throttle window
# If queue is full, new requests may be rejected (returns 429 Too Many Requests)
# Set based on expected burst load and memory available
# Typical: 500 (small) to 5000 (large)
# Default: 1000
# Formula: Consider THROTTLING_TPM * expected_wait_time
THROTTLING_MAX_QUEUE_SIZE=1000

# Throttling Queue Refill Interval (milliseconds)
# How often the throttle tokens are refilled during each minute
# Lower = more even distribution | Higher = tokens released in fewer, larger batches
# Typical: 100-2000ms | Default: 1000ms (refill every second, 60 times per minute)
# Formula: 60000 ms/minute ÷ desired_refills_per_minute
THROTTLING_REFILL_INTERVAL_MS=1000

# Auth Endpoint Rate Limit Window (milliseconds)
# Time window for counting requests to auth endpoints (/login, /register, /refresh)
# Example: 900000 = 15 minutes
# Protects against: credential stuffing, password brute force, token refresh spam
# Typical: 300000 (5 min) to 1800000 (30 min)
RATE_LIMIT_AUTH_WINDOW_MS=900000

# Auth Endpoint Rate Limit Maximum Requests
# Maximum number of auth requests allowed per RATE_LIMIT_AUTH_WINDOW_MS
# Example: 10 means max 10 login attempts per 15 minutes per IP/user
# Set low to prevent brute force: 3-20 attempts
# Balance: Too low breaks legitimate users (forgot password, retry after error)
RATE_LIMIT_AUTH_MAX=10

# General API Rate Limit Window (milliseconds)
# Time window for counting requests to normal API endpoints
# Example: 60000 = 1 minute
# Protects against: request floods, DDoS attacks
# Typical: 60000 (1 min) or 3600000 (1 hour)
RATE_LIMIT_API_WINDOW_MS=60000

# General API Rate Limit Maximum Requests
# Maximum number of general API requests allowed per RATE_LIMIT_API_WINDOW_MS
# Example: 100 means max 100 requests per minute per IP/user
# Set based on expected usage patterns of legitimate users
# Typical: 50-500 requests per minute
RATE_LIMIT_API_MAX=100

# Data-Heavy Endpoint Rate Limit Window (milliseconds)
# Time window for data export, report generation, large list endpoints
# May need higher limits due to legitimate bulk operations
# Example: 60000 = 1 minute
RATE_LIMIT_DATA_WINDOW_MS=60000

# Data-Heavy Endpoint Rate Limit Maximum Requests
# Maximum data-heavy requests allowed per RATE_LIMIT_DATA_WINDOW_MS
# Can be higher than general API limit; data endpoints are less sensitive to spam
# Example: 200 means max 200 data requests per minute per IP/user
# Set based on expected report/export usage
RATE_LIMIT_DATA_MAX=200


# =============================================================================
# Stellar Blockchain Network Configuration (REQUIRED - contracts + transactions)
# =============================================================================

# Stellar Network Selection
# Which Stellar network to connect to
# Values: testnet (development/testing, free, resets monthly)
#         mainnet (production, real XLM, real transactions)
#         public (synonym for mainnet)
# Default: testnet
# Test first on testnet! Never use mainnet unless ready for production
# Cost: Testnet = free | Mainnet = costs real XLM
STELLAR_NETWORK=testnet

# Stellar Network Passphrase
# Cryptographic identifier for the specific network
# Must match the STELLAR_NETWORK selection exactly
# Mismatches: Causes signature verification failures
# Testnet passphrase: "Test SDF Network ; September 2015"
# Mainnet passphrase: "Public Global Stellar Network ; September 2015"
# This passphrase is included in every transaction signature
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Stellar Horizon API Endpoint
# REST API endpoint for reading Stellar ledger data and submitting transactions
# Must be compatible with STELLAR_NETWORK selection
# Testnet: https://horizon-testnet.stellar.org (or local) OR http://localhost:8000
# Mainnet: https://horizon.stellar.org (production SDF endpoint)
# Custom/Local: http://localhost:8000 (for local Stellar Docker network)
# Fallback to default if omitted; specify custom endpoint for non-standard networks
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Stellar Transaction Retry Configuration
# How many times to retry failed Stellar transaction submissions
# Network issues (timeouts) trigger automatic retry with exponential backoff
# Typical: 1-5 retries
# Default: 3
# Higher = more resilient but slower failure propagation
STELLAR_MAX_RETRIES=3

# Stellar Transaction Retry Base Delay (milliseconds)
# Initial delay before first retry (subsequent retries use exponential backoff)
# Example: 1000 = wait 1 second before first retry
# Balances: Too short = fails immediately | Too long = delays recovery
# Typical: 500-2000ms
STELLAR_RETRY_DELAY_MS=1000

# Stellar Transaction Retry Maximum Delay (milliseconds)
# Maximum delay cap between retries to avoid excessive wait times
# Used with exponential backoff: delay = min(delay * 2, STELLAR_RETRY_DELAY_MAX_MS)
# Example: 10000 = max 10 second wait between retries
# Typical: 5000-30000ms
STELLAR_RETRY_DELAY_MAX_MS=10000

# Stellar Explorer URL Base
# Public URL for links to transaction details (for emails, UI links)
# Format: https://stellar.expert/explorer/{network}/tx/
# For testnet: https://stellar.expert/explorer/testnet/tx/
# For mainnet: https://stellar.expert/explorer/testnet/tx/ (note: same domain, different path)
# Alternative explorer: https://laboratory.stellar.org/#explorer/
# This URL is appended with transaction hash for final link
STELLAR_EXPLORER_URL=https://stellar.expert/explorer/testnet/tx

# Soroban RPC endpoint for contract-related operations.
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Horizon client retry configuration.
STELLAR_MAX_RETRIES=3
STELLAR_RETRY_DELAY_MS=1000
STELLAR_RETRY_DELAY_MAX_MS=10000

# Optional pathfinding APIs used by cross-asset services.
SOROSWAP_API_URL=https://api.soroswap.finance
STELLARDEX_API_URL=

# Event indexer controls.
SOROBAN_EVENT_START_LEDGER=0
SOROBAN_EVENT_POLL_INTERVAL_MS=12000

# Optional direct contract IDs for event indexing fallback.
BULK_PAYMENT_CONTRACT_ID=
VESTING_ESCROW_CONTRACT_ID=
REVENUE_SPLIT_CONTRACT_ID=

# -----------------------------------------------------------------------------
# Asset issuer overrides (optional)
# -----------------------------------------------------------------------------
# ORGUSD accounts populated by scripts/issue-orgusd.ts.
ORGUSD_ISSUER_PUBLIC=
ORGUSD_ISSUER_SECRET=
ORGUSD_DISTRIBUTION_PUBLIC=
ORGUSD_DISTRIBUTION_SECRET=

# Override default stablecoin issuers only when necessary.
USDC_ISSUER_PUBLIC=
EURC_ISSUER_PUBLIC=

# Optional issuance amount used by backend/scripts/issue-orgusd.ts
ORGUSD_ISSUE_AMOUNT=1000000

# -----------------------------------------------------------------------------
# Email notifications
# -----------------------------------------------------------------------------
# Supported providers in current schema: resend | sendgrid
EMAIL_PROVIDER=resend

# Sender metadata shown in payroll notification emails.
EMAIL_FROM_ADDRESS=noreply@payd.example.com
EMAIL_FROM_NAME="PayD Payroll System"

# Provider API keys (set the one matching EMAIL_PROVIDER).
RESEND_API_KEY=re_xxxxxxxxxxxxx
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Queue processing settings for notification retries.
NOTIFICATION_QUEUE_NAME=payment-notifications
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=5000

# Explorer base URL used in emailed transaction links.
STELLAR_EXPLORER_URL=https://stellar.expert/explorer/testnet/tx

# -----------------------------------------------------------------------------
# Optional platform integrations
# -----------------------------------------------------------------------------
# Stellar Disbursement Server integration settings.
SDS_ENABLE=false
SDS_API_KEY=your-sds-api-key-here
SDS_ENDPOINT=https://sds-api.stellar.org
SDS_TIMEOUT=30000
SDS_RETRY_ATTEMPTS=3
SDS_RETRY_DELAY=1000

# -----------------------------------------------------------------------------
# Operational diagnostics + feature flags
# -----------------------------------------------------------------------------
# Logging level: debug | info | warn | error
LOG_LEVEL=debug

# Build metadata shown by health endpoints.
BUILD_TIMESTAMP=
BUILD_TIME=

# Local cache controls.
ENABLE_CACHING=true
CACHE_TTL=3600

# -----------------------------------------------------------------------------
# Monitoring / Observability (ELK stack + tracing + metrics)
# -----------------------------------------------------------------------------
# Elasticsearch — set ELASTICSEARCH_ENABLED=true to ship logs to ES.
# Start the full monitoring stack: docker compose -f docker-compose.yml -f docker-compose.monitoring.yml up
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# OpenTelemetry distributed tracing — set TRACING_ENABLED=true to export spans.
# Default collector: Jaeger at localhost:4318 (OTLP/HTTP).
TRACING_ENABLED=false
OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Optional bearer token to restrict access to GET /metrics (Prometheus scraping).
# Leave empty to allow unauthenticated scraping (suitable for private networks).
METRICS_TOKEN=

# Grafana admin credentials (used by docker-compose.monitoring.yml).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=payd_grafana
