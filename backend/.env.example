# -----------------------------------------------------------------------------
# PayD backend environment template
# -----------------------------------------------------------------------------
# Copy this file to `backend/.env` before running backend services:
#   cp backend/.env.example backend/.env
#
# Security notes:
# - Never commit real secrets to version control.
# - Use long, random values for JWT and OAuth client secrets.
# - Use production-grade credentials in staging/production only.

# -----------------------------------------------------------------------------
# Core server runtime (required)
# -----------------------------------------------------------------------------
# API port the backend listens on.
PORT=3001

# App environment: development | production | test
NODE_ENV=development

# CORS origin allowed by backend APIs.
CORS_ORIGIN=http://localhost:5173

# Optional additional CORS origins (comma-separated), e.g. staging + production apps.
# CORS_ALLOWED_ORIGINS=https://staging.payd.io,https://app.payd.io

# Frontend base URL used for auth redirects.
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Authentication and session security (required)
# -----------------------------------------------------------------------------
# JWT signing secret used for short-lived access tokens.
JWT_SECRET=replace-with-a-long-random-secret

# JWT signing secret used for refresh tokens.
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret

# OAuth provider credentials (required only if social login is enabled)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# -----------------------------------------------------------------------------
# Database + cache (required for full backend functionality)
# -----------------------------------------------------------------------------
# Primary Postgres connection string used by app and migrations.
DATABASE_URL=postgresql://payd_user:payd_password@localhost:5432/payd_db

# Optional split DB settings (kept for compatibility with legacy config paths).
DB_HOST=localhost
DB_PORT=5432
DB_USER=payd_user
DB_PASSWORD=payd_password
DB_NAME=payd_db

# Optional Redis URL (currently optional in schema).
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Rate limiting + transaction throttling (recommended)
# -----------------------------------------------------------------------------
# Token-per-minute throttle for contract operations.
THROTTLING_TPM=100

# Max queued throttled requests in memory.
THROTTLING_MAX_QUEUE_SIZE=1000

# Queue refill interval in milliseconds.
THROTTLING_REFILL_INTERVAL_MS=1000

# Auth endpoint limiter (window + max requests).
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10

# General API limiter (window + max requests).
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX=100

# Data-heavy endpoint limiter (window + max requests).
RATE_LIMIT_DATA_WINDOW_MS=60000
RATE_LIMIT_DATA_MAX=200

# -----------------------------------------------------------------------------
# Stellar network + contracts
# -----------------------------------------------------------------------------
# Network identifier used in several backend services.
# Examples: testnet | mainnet | public
STELLAR_NETWORK=testnet

# Stellar passphrase and Horizon URL.
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC endpoint for contract-related operations.
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Horizon client retry configuration.
STELLAR_MAX_RETRIES=3
STELLAR_RETRY_DELAY_MS=1000
STELLAR_RETRY_DELAY_MAX_MS=10000

# Optional pathfinding APIs used by cross-asset services.
SOROSWAP_API_URL=https://api.soroswap.finance
STELLARDEX_API_URL=

# Event indexer controls.
SOROBAN_EVENT_START_LEDGER=0
SOROBAN_EVENT_POLL_INTERVAL_MS=12000

# Optional direct contract IDs for event indexing fallback.
BULK_PAYMENT_CONTRACT_ID=
VESTING_ESCROW_CONTRACT_ID=
REVENUE_SPLIT_CONTRACT_ID=

# -----------------------------------------------------------------------------
# Asset issuer overrides (optional)
# -----------------------------------------------------------------------------
# ORGUSD accounts populated by scripts/issue-orgusd.ts.
ORGUSD_ISSUER_PUBLIC=
ORGUSD_ISSUER_SECRET=
ORGUSD_DISTRIBUTION_PUBLIC=
ORGUSD_DISTRIBUTION_SECRET=

# Override default stablecoin issuers only when necessary.
USDC_ISSUER_PUBLIC=
EURC_ISSUER_PUBLIC=

# Optional issuance amount used by backend/scripts/issue-orgusd.ts
ORGUSD_ISSUE_AMOUNT=1000000

# -----------------------------------------------------------------------------
# Email notifications
# -----------------------------------------------------------------------------
# Supported providers in current schema: resend | sendgrid
EMAIL_PROVIDER=resend

# Sender metadata shown in payroll notification emails.
EMAIL_FROM_ADDRESS=noreply@payd.example.com
EMAIL_FROM_NAME="PayD Payroll System"

# Provider API keys (set the one matching EMAIL_PROVIDER).
RESEND_API_KEY=re_xxxxxxxxxxxxx
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Queue processing settings for notification retries.
NOTIFICATION_QUEUE_NAME=payment-notifications
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=5000

# Explorer base URL used in emailed transaction links.
STELLAR_EXPLORER_URL=https://stellar.expert/explorer/testnet/tx

# -----------------------------------------------------------------------------
# Optional platform integrations
# -----------------------------------------------------------------------------
# Stellar Disbursement Server integration settings.
SDS_ENABLE=false
SDS_API_KEY=your-sds-api-key-here
SDS_ENDPOINT=https://sds-api.stellar.org
SDS_TIMEOUT=30000
SDS_RETRY_ATTEMPTS=3
SDS_RETRY_DELAY=1000

# -----------------------------------------------------------------------------
# Operational diagnostics + feature flags
# -----------------------------------------------------------------------------
# Logging level: debug | info | warn | error
LOG_LEVEL=debug

# Build metadata shown by health endpoints.
BUILD_TIMESTAMP=
BUILD_TIME=

# Local cache controls.
ENABLE_CACHING=true
CACHE_TTL=3600
